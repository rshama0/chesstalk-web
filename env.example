# Optional: rewrite pinned https://chessbird.app URLs (OG, Twitter, favicon, manifest) for another host,
# e.g. GitHub Pages preview: https://user.github.io/repo  (no trailing slash).
# Run: CHESSBIRD_PUBLIC_ORIGIN=https://user.github.io/repo npm run inject:public-origin
# CHESSBIRD_PUBLIC_ORIGIN=https://user.github.io/repo

# Alternative name (same effect):
# PUBLIC_APP_BASE_URL=https://user.github.io/repo
