# Set before deploy so OG/Twitter/favicon/manifest use absolute HTTPS URLs in built HTML.
# Run: CHESSBIRD_PUBLIC_ORIGIN=https://www.example.com npm run inject:public-origin
CHESSBIRD_PUBLIC_ORIGIN=https://www.example.com

# Alternative name (same effect as CHESSBIRD_PUBLIC_ORIGIN in inject script):
# PUBLIC_APP_BASE_URL=https://www.example.com
